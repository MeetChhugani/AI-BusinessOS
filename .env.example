# Environment Configuration
ENVIRONMENT=development  # development, production, testing
PROJECT_NAME="AI BusinessOS"
API_V1_STR="/api/v1"

# Security
JWT_SECRET_KEY=generate_a_very_long_random_secure_hex_key_here_for_jwt_signing
JWT_REFRESH_SECRET_KEY=generate_another_long_random_secure_hex_key_for_refresh_jwt_signing
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=ai_businessos
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@db:5432/ai_businessos

# Caching & Rate Limiting (Redis)
REDIS_URL=redis://redis:6379/0

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Seed Admin Credentials
FIRST_SUPER_ADMIN_EMAIL=superadmin@businessos.com
FIRST_SUPER_ADMIN_PASSWORD=SuperSecurePassword123!
